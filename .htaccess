# ARQUIVO: .htaccess
RewriteEngine On
RewriteBase /

# Permitir acesso direto a arquivos e diretórios reais
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirecionar /login para login.php
RewriteRule ^login/?$ login.php [L]

# Redirecionar /logout
RewriteRule ^logout/?$ includes/auth.php?logout=1 [L]

# Rotear /app_api.php através de index.php
RewriteRule ^app_api\.php$ index.php [L]

# Rotear /app através de index.php
RewriteRule ^app/?$ index.php [L]
